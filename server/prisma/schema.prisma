generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  email         String   @unique
  password_hash String
  name          String
  role          String   @default("user") // "admin" | "user"
  created_at    DateTime @default(now())

  companies     Company[]
}

model Company {
  id              String   @id @default(uuid())
  name            String
  logo_url        String?
  primary_color   String?
  secondary_color String?
  user_id         String
  user            User     @relation(fields: [user_id], references: [id])
  
  wines           Wine[]
}

model Wine {
  id               String   @id @default(uuid())
  name             String
  region           String
  subregion        String?
  country          String
  vintage          Int?
  grape            String
  type             String   // red/white/rose/sparkling
  bottle_size      String?
  supplier         String?
  winery           String?
  purchase_price   Float
  sell_price       Float?
  stock_count      Int      @default(0)
  min_stock_alert  Int      @default(0)
  days_in_stock    Int      @default(0)
  company_id       String
  company          Company  @relation(fields: [company_id], references: [id])
  created_at       DateTime @default(now())

  stock_movements  StockMovement[]
}

model StockMovement {
  id          String   @id @default(uuid())
  wine_id     String
  wine        Wine     @relation(fields: [wine_id], references: [id])
  type        String   // purchase/sale/adjustment
  quantity    Int
  note        String?
  created_at  DateTime @default(now())
}

model WineCatalog {
  id               String   @id @default(uuid())
  name             String   @unique
  region           String
  subregion        String?
  country          String
  vintage          Int?
  grape            String?
  type             String
  bottle_size      String?
  image_url        String?

  // Detailed information
  elaborate        String?
  harmonize        String?
  abv              Float?
  body             String?
  acidity          String?
  winery           String?
  website          String?

  is_verified      Boolean  @default(true)
  created_at       DateTime @default(now())
}

